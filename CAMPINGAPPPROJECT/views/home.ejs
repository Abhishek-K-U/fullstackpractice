<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yelp-Camp</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="/style/home.css">
</head>
<body class="d-flex text-center text-white bg-dark">
  <div class="cover-container d-flex w-100 h-100 p-3 mx-auto flex-column">
    <header class="mb-auto">
        <div class="d-flex justify-content-between align-items-center">
            <h3 class="float-md-left mb-0">YelpCamp</h3>
            <nav class="navbar nav-masthead justify-content-center float-md-right">
                <a class="nav-link active" aria-current="page" href="#">Home</a>
                <a class="nav-link" href="/campgrounds">Campgrounds</a>
                <a class="nav-link" href="/campgrounds/new">New Campgrounds</a>
                <% if(!currentUser){ %>
                <a class="nav-link" href="/login">Login</a>
                <a class="nav-link" href="/register">Register</a>
                <% }else{ %>
                <a class="nav-link" href="/logout">Logout</a>
                <%  } %>
            </nav>
        </div>
    </header>
    <main class="px-3 d-flex flex-column justify-content-center align-items-center vh-100">
        <h1>Welcome to YelpCamp</h1>
        <p class="lead">Discover and share your favorite camping spots with the world. Join our community of outdoor enthusiasts and start exploring today!</p>
        <p class="lead">
            <a href="/campgrounds" class="btn btn-lg btn-secondary fw-bold border-white bg-white">View Campgrounds</a>
        </p>
    </main>
    <footer class="mt-auto text-white-50">
        <p>YelpCamp &copy; 2024. All rights reserved.</p>
    </footer>
</div>
    
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js" integrity="sha384-IQsoLXl5PILFhosVNubq5LC7Qb9DXgDA9i+tQ8Zj3iwWAwPtgFTxbJ8NT4GN1R8p" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.min.js" integrity="sha384-cVKIPhGWiC2Al4u+LWgxfKTRIcfu0JTxR+EQDz/bgldoEyl4H0zUF0QKbrJ0EcQF" crossorigin="anonymous"></script>
</body>
</html>
